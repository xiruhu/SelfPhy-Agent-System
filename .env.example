# SelfPhy-Agent-System 配置文件

# Claude / Anthropic (Supervisor Agent - 使用第三方代理)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_BASE_URL=your_anthropic_base_url_here

# OpenAI / GPT-4o (备选 Supervisor Agent)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=your_openai_base_url_here

# Kimi (Moonshot) - 被测模型
MOONSHOT_API_KEY=your_moonshot_api_key_here
MOONSHOT_BASE_URL=your_moonshot_base_url_here

# MiniMax - 被测模型
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_BASE_URL=your_minimax_base_url_here

# Doubao (豆包) - 被测模型
DOUBAO_API_KEY=your_doubao_api_key_here
DOUBAO_ENDPOINT=your_doubao_endpoint_here
